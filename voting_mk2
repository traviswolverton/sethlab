def get_age():
    while True:
        try:
            age = int(input("Please enter your age: "))
            if age >= 0:
                return age
            else:
                print("Please enter a non-negative age.")
        except ValueError:
            print("Invalid input. Please enter a valid number.")

def get_citizenship():
    while True:
        citizen_input = input("Are you a citizen? (y/n): ").strip().lower()
        if citizen_input in ["y", "n"]:
            return citizen_input == "y"
        else:
            print("Invalid input. Please enter 'y' for yes or 'n' for no.")

def check_voting_eligibility():
    age = get_age()
    is_citizen = get_citizenship()
    is_of_voting_age = age >= 18
    is_eligible_to_vote = is_of_voting_age and is_citizen

    if is_eligible_to_vote:
        print("Congratulations! You are eligible to vote.")
    else:
        print("You are not eligible to vote.")

check_voting_eligibility()